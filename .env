# Application
APP_NAME=AI Data Agent
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# Database
DATABASE_URL=mysql+aiomysql://root:123456@localhost:3306/ai_data_agent
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# PostgreSQL (alternative)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/data_agent

# LLM Configuration - aiznt.com (稳定提供商)
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-nDmxSZRAxKgypZVBG7u9oIPwSVz6CnHiyIammWKn7lDqFCT9
LLM_API_BASE=https://api-us.aiznt.com
LLM_MODEL=claude-sonnet-4-5-20250929
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# MiniMax (不稳定，已弃用)
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-cp-b9-yITc2R_pY9ckBiaRro13OUaABhnPov_zs4Xv5eX-lfokaKyVVv1ZdOBO4mWh8ObE4nrONzVAFbYOKd9tKENZNbLnJkaY1Bs67PTHHXK1_rfYapcSUbLg
