{
  "config_id": "alpha_vantage_stock",
  "name": "Alpha Vantage 股票API",
  "description": "提供实时和历史股票数据查询服务，支持全球主要股票市场",
  "base_url": "https://www.alphavantage.co/query",
  "auth": {
    "type": "api_key",
    "api_key_header": "apikey",
    "api_key_value": "BEX015VSNDBAWP31"
  },
  "endpoints": {
    "daily": {
      "path": "",
      "method": "GET",
      "description": "获取股票每日时间序列数据",
      "params_mapping": {
        "stock_symbol": "symbol"
      },
      "required_params": ["symbol"],
      "default_params": {
        "function": "TIME_SERIES_DAILY"
      },
      "response_data_path": "Time Series (Daily)",
      "response_field_mapping": {
        "date": "date",
        "open": "1. open",
        "high": "2. high",
        "low": "3. low",
        "close": "4. close",
        "volume": "5. volume"
      }
    }
  },
  "timeout": 30,
  "retry_count": 3,
  "is_active": true
}
