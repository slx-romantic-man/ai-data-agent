# Application
APP_NAME=AI Data Agent
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# Database
DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/data_agent
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# PostgreSQL (alternative)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/data_agent

# LLM Configuration
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Aliyun LLM (alternative)
# LLM_PROVIDER=aliyun
# LLM_API_KEY=your-aliyun-api-key
# LLM_API_BASE=https://dashscope.aliyuncs.com/api/v1
# LLM_MODEL=qwen-max

# Authentication
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Permission
ENABLE_PERMISSION_CHECK=true
DEFAULT_DATA_SCOPE=department

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log